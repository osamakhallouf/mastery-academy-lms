# Database
# Prisma connection string (e.g. postgresql://user:pass@host:5432/dbname)
DATABASE_URL=

# Stripe
# Secret key from Stripe Dashboard (starts with sk_)
STRIPE_API_KEY=
# Webhook signing secret (whsec_...) for verifying Stripe webhook events
STRIPE_WEBHOOK_SECRET=

# Clerk (auth)
# Server-side secret from Clerk Dashboard
CLERK_SECRET_KEY=
# Publishable key for client-side Clerk (starts with pk_)
CLERK_PUBLISHABLE_KEY=

# Teacher access
# Clerk user ID of the teacher account (enables teacher routes)
TEACHER_USER_ID=

# Upstash Redis (rate limiting)
# REST API URL and token from Upstash Redis console
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend (email)
# API key from Resend for sending transactional email
RESEND_API_KEY=

# App URL
# Public base URL of the app (e.g. https://example.com), used for redirects and links
NEXT_PUBLIC_APP_URL=

# Mux (video)
# Credentials from Mux Dashboard for video upload and playback
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Admin
# Email address that receives corporate inquiry notifications
ADMIN_EMAIL=
